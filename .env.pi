# Pi-friendly scraper configuration
# Lower settings to prevent CPU overload and rate limiting

MAX_RETRIES=2
RETRY_DELAY=2000
BATCH_SIZE=3
CONCURRENT_LIMIT=2
REQUEST_TIMEOUT=20000
USER_AGENT=Mozilla/5.0 (compatible; DokkanScraper/2.0; Pi5-Friendly)

# Optional: Enable this if you want even gentler scraping
# DELAY_BETWEEN_BATCHES=1000